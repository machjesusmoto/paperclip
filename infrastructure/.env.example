# Per-agent OpenRouter API keys + Discord bot tokens for the TAYA fleet.
#
# DO NOT commit real values. Copy this file to `.env` and fill in real
# keys from Vault (see infra/scripts/sync-env-from-vault.py for the
# automation).
#
# Regenerate from Vault (writes .env automatically):
#   python3 infrastructure/scripts/sync-env-from-vault.py
#
# Verify .env matches Vault (exit 0 if matches, 1 if drift):
#   python3 infrastructure/scripts/sync-env-from-vault.py --check
#
# Source of truth — Vault paths:
#   - Per-agent OR keys:   secret/hermes/openrouter-api-keys/<agent>
#   - Discord bot tokens:  secret/hermes/<agent>/discord-bot-token-<agent>-*
#
# Compose variable → Vault field name mapping:
#   OPENROUTER_API_KEY_ZEPHYR       → openrouter-api-keys.zephyr
#   OPENROUTER_API_KEY_PHOENIX      → openrouter-api-keys.phoenix
#   OPENROUTER_API_KEY_ORBIT        → openrouter-api-keys.orbit
#   OPENROUTER_API_KEY_PM           → openrouter-api-keys.project-manager
#   OPENROUTER_API_KEY_REVIEWER     → openrouter-api-keys.code-reviewer
#   OPENROUTER_API_KEY_RESEARCHER   → openrouter-api-keys.researcher
#   OPENROUTER_API_KEY_WRITER       → openrouter-api-keys.technical-writer
#   OPENROUTER_API_KEY_KHAOS        → openrouter-api-keys.khaos
#   DISCORD_BOT_TOKEN_ZEPHYR        → secret/hermes/zephyr/discord-bot-token-zephyr-openclaw.token
#   DISCORD_BOT_TOKEN_ORBIT         → secret/hermes/orbit/discord-bot-token-orbit.Token

OPENROUTER_API_KEY_ZEPHYR=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_PHOENIX=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_ORBIT=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_PM=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_REVIEWER=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_RESEARCHER=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_WRITER=sk-or-v1-REPLACE_ME
OPENROUTER_API_KEY_KHAOS=sk-or-v1-REPLACE_ME

DISCORD_BOT_TOKEN_ZEPHYR=REPLACE_ME
DISCORD_BOT_TOKEN_ORBIT=REPLACE_ME